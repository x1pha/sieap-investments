{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sieap-investments",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-09",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
